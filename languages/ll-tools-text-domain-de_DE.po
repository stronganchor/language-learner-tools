msgstr "Die Lehrerrolle konnte diesem Benutzer nicht zugewiesen werden."

#: includes/user-roles/wordset-manager.php:198
msgid "Word Set Manager Assignment"
msgstr "Vokabelset-Manager-Zuweisung"

#: includes/user-roles/wordset-manager.php:200
msgid ""
"Choose the primary word set this user is allowed to manage. Additional "
"manager assignments can be added from each word set settings page."

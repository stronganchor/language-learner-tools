msgid "Invalid word for this word set."
msgstr "Ungültige Vokabel für dieses Vokabelset."

#: includes/admin/ipa-keyboard-admin.php:3378
msgid "This word already has written text."
msgstr "Diese Vokabel hat bereits geschriebenen Text."

#: includes/admin/ipa-keyboard-admin.php:3383
msgid "No IPA recording is available for this word."
msgstr "Für diese Vokabel ist keine IPA-Aufnahme verfügbar."

#: includes/admin/ipa-keyboard-admin.php:3390

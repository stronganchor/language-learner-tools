#. translators: 1: target sound, 2: previous sounds
#: includes/admin/ipa-keyboard-admin.php:2130
msgid "Do not allow %1$s after %2$s."
msgstr "Erlaube %1$s nicht nach %2$s."

#. translators: 1: target sound, 2: next sounds
#: includes/admin/ipa-keyboard-admin.php:2139
msgid "Do not allow %1$s before %2$s."
msgstr "Erlaube %1$s nicht vor %2$s."


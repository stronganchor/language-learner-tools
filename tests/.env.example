WP_TEST_DB_NAME=local_test
WP_TEST_DB_USER=root
WP_TEST_DB_PASS=root
WP_TEST_DB_HOST=127.0.0.1:10019
WP_TESTS_DIR=/tmp/wordpress-tests-lib
WP_CORE_DIR=/tmp/wordpress

# Optional explicit binaries
# PHP_BIN=/usr/bin/php
# MYSQL_BIN=/usr/bin/mysql

# Optional Playwright E2E settings
# LL_E2E_BASE_URL=http://127.0.0.1:10036
# LL_E2E_LEARN_PATH=/learn/
# LL_E2E_STANDALONE_PATH=/english/
#
# Optional network-throttled page-speed regression settings
# LL_E2E_PAGE_SPEED_PATH=/learn/
# LL_E2E_PAGE_SPEED_SELECTOR=.ll-quiz-page-trigger
# LL_E2E_PAGE_SPEED_LATENCY_MS=150
# LL_E2E_PAGE_SPEED_DOWNLOAD_KBPS=1600
# LL_E2E_PAGE_SPEED_UPLOAD_KBPS=750
# LL_E2E_PAGE_SPEED_CPU_SLOWDOWN_RATE=1
# LL_E2E_PAGE_SPEED_MAX_DOMCONTENTLOADED_MS=7000
# LL_E2E_PAGE_SPEED_MAX_ACTIONABLE_MS=10000
# LL_E2E_PAGE_SPEED_MAX_LOAD_MS=15000
#
# Optional large-wordset page-speed regression settings
# LL_E2E_WORDSET_PAGE_SPEED_PATH=/genc-palu/
# LL_E2E_WORDSET_PAGE_SPEED_SELECTOR=.ll-wordset-card[data-cat-id]:not(.ll-wordset-card--lazy-placeholder):not([data-ll-wordset-inline-placeholder])
# LL_E2E_WORDSET_PAGE_SPEED_ROOT_SELECTOR=[data-ll-wordset-page], .ll-wordset-page
# LL_E2E_WORDSET_PAGE_SPEED_MIN_CARDS=18
# LL_E2E_WORDSET_PAGE_SPEED_MAX_DOMCONTENTLOADED_MS=12000
# LL_E2E_WORDSET_PAGE_SPEED_MAX_ACTIONABLE_MS=12000
# LL_E2E_WORDSET_PAGE_SPEED_MAX_LOAD_MS=20000

# Opt-in seeded performance benchmark. Prefer tests/bin/run-performance-benchmark.sh
# so the static ll-perf-* fixture is reused when current or refreshed when stale.
# Progress scenarios require LL_E2E_ADMIN_USER and LL_E2E_ADMIN_PASS.
# LL_PERF_FORCE_SEED=1
# LL_PERF_SEED_ONLY=1
# LL_PERF_SKIP_SEED=1
# LL_E2E_PERF_ENABLED=1
# LL_E2E_PERF_RUNS=3
# LL_E2E_PERF_WRITE_HISTORY=1
# LL_E2E_PERF_COMPARE_HISTORY=1
# LL_E2E_PERF_HISTORY_FILE=tests/performance/history/performance-history.jsonl
# LL_E2E_PERF_MAX_REGRESSION_RATIO=0.2
# LL_E2E_PERF_MAX_REGRESSION_MS=500
